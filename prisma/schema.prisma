generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Faction {
  Demon
  Knight
  Mutant
  Anomaly
}

model Character {
  id           String   @id @default(cuid())
  name         String
  type         Faction
  hp           Int      @default(0)
  level        String   @default("1")
  passiveSkill String?
  activeSkill  String?
  specialSkill String?
  imageUrl     String?
  winCondition String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum CardType {
  Equipment
  Investigation
  Effect
  Support
}

model Card {
  id        String   @id @default(cuid())
  name      String
  type      CardType
  effect    String?
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum MechanicCategory {
  Matchmaking
  Gameplay
  CardPool
}

model Mechanic {
  id        String           @id @default(cuid())
  category  MechanicCategory
  rules     Json             // Stores array of strings
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model Region {
  id                 String   @id @default(cuid())
  orderNumber        Int      @unique
  nameAndDescription String
  effect             String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("TODO") // TODO, IN_PROGRESS, REVIEW, DONE
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MiniBoss {
  id          String   @id @default(cuid())
  bossName    String
  hp          Int      @default(0)
  atk         Int      @default(0)
  effect      String?
  bossReward  String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SpecialEquipment {
  id        String   @id @default(cuid())
  name      String
  effect    String?
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
